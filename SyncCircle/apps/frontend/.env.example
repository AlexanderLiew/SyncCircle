# Friends Backend API base URL (API Gateway endpoint)
# e.g. https://abc123.execute-api.ap-southeast-1.amazonaws.com/prod
VITE_API_BASE_URL=https://api.synccircle.placeholder.dev

# Workato webhook base URL — copy from your Workato recipe trigger
# e.g. https://apim.workato.com/your-org/synccircle-timetable-v1
VITE_WORKATO_WEBHOOK_URL=https://hooks.workato.com/webhooks/placeholder

# Kiro AI API base URL (for note summarization and AI planner chat)
VITE_KIRO_API_URL=https://api.kiro.placeholder.dev

# AWS Cognito — from your deployed Friends Backend stack outputs
VITE_COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-app-client-id
